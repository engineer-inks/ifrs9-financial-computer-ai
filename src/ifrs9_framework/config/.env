# ==========================================
# CONFIGURAÇÃO DE AMBIENTE: MAC (APPLE SILICON/INTEL)
# ==========================================

# O Docker vai ler APENAS o ficheiro base (modo CPU)
COMPOSE_FILE=docker-compose.yml

# Diz ao nosso pipeline_orchestrator.py para não tentar usar CUDA
USE_GPU=False


# ------------------------------------------
# NOTA PARA QUANDO VOLTAR PARA O WINDOWS:
# Comente as duas linhas acima e descomente as duas abaixo:
# ------------------------------------------
# COMPOSE_FILE=docker-compose.yml:docker-compose.gpu.yml
# USE_GPU=True