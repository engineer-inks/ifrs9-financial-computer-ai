# ==========================================
# CONFIGURAÇÃO DE AMBIENTE: MAC (APPLE SILICON/INTEL)
# ==========================================
# O Docker vai ler APENAS o ficheiro base (modo CPU)
# COMPOSE_FILE=docker-compose.yml
# USE_GPU=False


# ==========================================
# CONFIGURAÇÃO DE AMBIENTE: WINDOWS (NVIDIA GPU)
# ==========================================

# A forma mais segura para evitar problemas de path no GitBash/WSL
# é usar o separador de caminho correto para o seu terminal ou
# não usar a variável COMPOSE_FILE para a concatenação se o terminal falhar.
# Vamos tentar com ponto e vírgula (padrão Windows) primeiro:
COMPOSE_FILE=docker-compose.yml;docker-compose.gpu.yml
USE_GPU=True